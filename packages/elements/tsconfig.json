{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "types": [],
    "declaration": true,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": false,
    "useDefineForClassFields": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src"]
}
